# XMRig Automation - Git Ignore File

# Live mining config with real wallet address. The tracked reference is
# config/config-template.json; config.json is populated locally and NOT
# committed. (Previously tracked; untracked as of this change. The address
# is a public Monero RECEIVE address, so no funds/keys are exposed, but it
# still exists in prior git history -- rotate the address if you want the
# operator identity unlinked from those old commits.)
config/config.json

# XMRig executable and binaries (users should download their own)
*.exe
*.dll
*.sys

# Log files
*.log
logs/
restart-log.txt

# Backup files
backups/
*.bak
*.backup

# Windows system files
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Temporary files
*.tmp
*.temp
~*

# IDE and editor files
.vscode/
.idea/
.history/
*.swp
*.swo
*~

# Security policy export files
secpol.cfg
secedit.sdb

# Windows shortcuts
*.lnk

# Archive files (unless specifically needed)
*.zip
*.rar
*.7z

# Node modules (if any)
node_modules/

# Python cache (if any)
__pycache__/
*.pyc
*.pyo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
