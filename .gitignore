# XMRig Automation - Git Ignore File

# Sensitive wallet information (if you want to keep wallet private)
# Uncomment the next line if you want to exclude wallet from public repo:
# config/config.json

# XMRig executable and binaries (users should download their own)
*.exe
*.dll
*.sys

# Log files
*.log
logs/
restart-log.txt

# Backup files
backups/
*.bak
*.backup

# Windows system files
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Temporary files
*.tmp
*.temp
~*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Security policy export files
secpol.cfg
secedit.sdb

# Windows shortcuts
*.lnk

# Archive files (unless specifically needed)
*.zip
*.rar
*.7z

# Node modules (if any)
node_modules/

# Python cache (if any)
__pycache__/
*.pyc
*.pyo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
