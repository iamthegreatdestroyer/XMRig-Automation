# Copy this file to  deploy.env  (which is gitignored) and fill in the wallet.
# install-xmrig.sh reads WALLET_ADDRESS from deploy.env when --wallet is not passed.
#
# WALLET_ADDRESS is your PUBLIC Monero receive address -- the same one used by the Windows
# miner in config/config.json. It is a receive address only (no private keys/funds exposed),
# but it is kept out of git so the operator identity is not linked to new commits.
WALLET_ADDRESS=
